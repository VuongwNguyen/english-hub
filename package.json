{
  "name": "english-daily-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx --env-file=.env.local src/server/run-seed.ts",
    "backfill:lesson-slugs": "tsx --env-file=.env.local src/server/backfill-lesson-slugs.ts",
    "sync:sources": "tsx --env-file=.env.local src/server/run-sync-sources.ts",
    "sync:words": "tsx --env-file=.env.local src/server/run-sync-words.ts",
    "sync:sentences": "tsx --env-file=.env.local src/server/run-sync-sentences.ts",
    "sync:tasks:seed": "tsx --env-file=.env.local src/server/run-seed-sync-tasks.ts",
    "sync:tasks:run": "tsx --env-file=.env.local src/server/run-sync-worker.ts",
    "generate:lessons": "tsx --env-file=.env.local src/server/run-generate-lessons.ts",
    "data:bootstrap:tasks": "yarn sync:sources && yarn sync:tasks:seed && yarn sync:tasks:run && yarn generate:lessons",
    "sync:until-done": "./scripts/sync-until-done.sh",
    "sync:until-done:aggressive": "SYNC_MODE=aggressive SYNC_WORKER_BATCH_SIZE=150 SYNC_WORKER_CONCURRENCY=5 ./scripts/sync-until-done.sh",
    "sync:until-done:safe": "SYNC_MODE=normal SYNC_WORKER_BATCH_SIZE=20 SYNC_WORKER_CONCURRENCY=1 ./scripts/sync-until-done.sh"
  },
  "dependencies": {
    "mongoose": "^9.7.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
